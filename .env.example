# Database Configuration
# Set USE_SQLITE=true for local development without PostgreSQL
USE_SQLITE=true

# PostgreSQL Configuration (only needed if USE_SQLITE=false)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=secret_message_app
DATABASE_USER=postgres
DATABASE_PASSWORD=your_password_here

# Application Configuration
BASE_URL=http://localhost:3000
PORT=3000
NODE_ENV=development

# Security Configuration
BCRYPT_ROUNDS=10

# CORS Configuration (Production only)
# Comma-separated list of allowed origins
# Example: ALLOWED_ORIGINS=https://example.com,https://app.example.com
# If not set in production, all origins will be blocked
ALLOWED_ORIGINS=
