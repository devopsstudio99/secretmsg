{
  "name": "secret-message-app",
  "version": "1.0.0",
  "description": "A secure secret message sharing application with password protection",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:property": "vitest --run property",
    "db:init": "tsx src/database/init.ts"
  },
  "keywords": [
    "secret",
    "message",
    "password",
    "qrcode"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "bcrypt": "^5.1.1",
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "pg": "^8.11.3",
    "qrcode": "^1.5.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^20.11.19",
    "@types/pg": "^8.11.0",
    "@types/qrcode": "^1.5.5",
    "@types/supertest": "^7.2.0",
    "fast-check": "^3.15.1",
    "supertest": "^7.2.2",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "vitest": "^1.3.1"
  }
}
